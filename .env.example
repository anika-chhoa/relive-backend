# Server
PORT=5000
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# MongoDB (native driver, no Mongoose)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGODB_DB_NAME=relive

# Better Auth (Google OAuth only)
BETTER_AUTH_SECRET=replace-with-a-long-random-string

# Our own JWT — used for credentials login/register AND for the
# post-Google sync-session bridge. Keep this different from
# BETTER_AUTH_SECRET.
JWT_SECRET=replace-with-a-different-long-random-string

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudinary (signed upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gemini (AI Smart Listing Assistant)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Stripe (Book Now checkout) — demo charges in USD since Stripe doesn't
# support BDT settlement. Get the webhook secret from `stripe listen`
# locally or the Stripe Dashboard in production.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
